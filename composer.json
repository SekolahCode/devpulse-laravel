{
  "name": "devpulse/laravel",
  "version": "2.0.0",
  "description": "DevPulse Laravel SDK — auto error capture for Laravel apps",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "error-tracking", "monitoring", "logging", "devpulse"],
  "authors": [
    {
      "name": "SekolahCode",
      "homepage": "https://github.com/SekolahCode"
    }
  ],
  "autoload": {
    "psr-4": {
      "DevPulse\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DevPulse\\Laravel\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "devpulse/core": "^1.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpstan/phpstan": "^1.10"
  },
  "conflict": {
    "larastan/larastan": "*"
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse"
  },
  "extra": {
    "laravel": {
      "providers": [
        "DevPulse\\Laravel\\DevPulseServiceProvider"
      ],
      "aliases": {
        "DevPulse": "DevPulse\\Laravel\\DevPulseFacade"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
